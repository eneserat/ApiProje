@model List<ApiProjeWebUI.Dtos.CategoryDtos.ResultCategoryDto>

<section id="menu" class="menu section">

    <!-- Section Title -->
    <div class="container section-title" data-aos="fade-up">
        <h2>Tüm Menü</h2>
        <p><span>Lezzetli Menümüzü </span> <span class="description-title"> İnceleyin</span></p>
    </div><!-- End Section Title -->

    <div class="container">

        <ul class="nav nav-tabs d-flex justify-content-center" data-aos="fade-up" data-aos-delay="100">

            <li class="nav-item">
                <a class="nav-link active show" data-bs-toggle="tab" data-bs-target="#menu-all">
                    <h4>Tümü</h4>
                </a>
            </li>

            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" data-bs-target="#menu-@item.CategoryID">
                            <h4>@item.CategoryName</h4>
                        </a>
                    </li>
                }
            }
            

        </ul>

    </div>

</section>